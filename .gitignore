# 1. Very Large Data Files (Must be ignored for GitHub 100MB limit)
*.vcf
*.vcf.gz
*.vcf.tbi
*.txt.gz
*.gz
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# 2. Specific Data Directories to exclude completely
CP3/data/*
CP1/gene/CTD*.csv
CP2/data/*
!CP2/data/*.md
!CP3/data/*.md

# 3. Environment and OS files
.RData
.Rhistory
.Rproj.user
__pycache__/
*.pyc
.env
.venv/
env/
venv/
.DS_Store
Thumbs.db

# 4. Large intermediate results (Exclude CSVs larger than 50MB)
# We will manually add any huge output files if needed
CP1/results/*.csv
CP1/gene/*.csv

# 5. Non-CP projects (FaceRank, LLM Foundation)
FaceRank/
LLM_foundation/

# 6. Manuscript output documents (Word, PPT, etc.)
# We WILL track the markdown source and PDF, but exclude editable Office binaries
*.docx
*.pptx
*.doc
*.fig

# 7. Output Result Binaries (Exclude raw uncompressed figures to save space)
*.tiff
*.tif
*.jpg
*.jpeg

# 8. Unnecessary stray files
atropine.SDF
3KFD.pdb

# 9. Log files and debug scripts
CP3/results/*_log.txt
CP3/scripts/debug_*.R
CP1/results/pipeline_log*.txt

# 10. DO NOT IGNORE Submit_Manuscript and Revision files!
# These contain the core texts and recent C2/C3 codes.
!Submit_Manuscript/
!Revision/
